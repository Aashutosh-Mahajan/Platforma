# ============================================
# PLATFORMA - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values.

# ---- Database ----
# PostgreSQL: postgresql://user:password@localhost:5432/platforma
# Required. SQLite is disabled:
DATABASE_URL=

# ---- Django ----
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Redis (optional - for caching & Celery) ----
REDIS_URL=redis://localhost:6379/0

# ---- Email (console backend by default) ----
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@platforma.com

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_PLATFORM_NAME=Platforma
